# --- CMake 忽略内容 ---
# 忽略二进制构建目录（假设你的构建目录叫 build 或 cmake-build-debug）
/[Bb]uild/
/cmake-build-*/
/out/

# 忽略 CMake 生成的中间文件
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
Makefile
*.cmake

# --- VS Code 忽略内容 ---
# 忽略整个 .vscode 文件夹（包括任务配置、调试配置等）
.vscode/

# 如果你只想保留调试配置(launch.json)，但忽略本地设置，可以改用：
# .vscode/settings.json
# .vscode/ipch/

# --- 编译输出的二进制文件 ---
*.exe
*.out
*.app
*.o
*.obj
*.a
*.lib
*.so
*.dylib

# --- 其他常见垃圾文件 ---
.DS_Store
[Tt]humbs.db